# Copy to .env and fill with your keys. Never commit .env.

PORT=4242

# Site URL (used for return URLs)
SITE_URL=http://localhost:8080

# Razorpay — https://dashboard.razorpay.com/app/keys
# Use Test keys for development (rzp_test_...)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# Stripe — https://dashboard.stripe.com/apikeys (optional)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal — https://developer.paypal.com/dashboard/ (optional)
PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...
# sandbox | live
PAYPAL_MODE=sandbox

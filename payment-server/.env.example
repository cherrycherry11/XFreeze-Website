# Copy to .env and fill with your keys. Never commit .env.

PORT=4242

# Site URL (used for return URLs)
SITE_URL=http://localhost:8080

# Razorpay — https://dashboard.razorpay.com/app/keys
# Use Test keys for development (rzp_test_...)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# Stripe — https://dashboard.stripe.com/apikeys (optional)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal — https://developer.paypal.com/dashboard/ (optional)
PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...
# sandbox | live
PAYPAL_MODE=sandbox

# Supabase (server entitlements — required for Pro grants)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # secret — never ship to the browser
RAZORPAY_WEBHOOK_SECRET=           # Razorpay Dashboard → Webhooks
ALLOWED_ORIGINS=http://localhost:8080,https://xfreeze.com

# Paddle — https://developer.paddle.com/
# Sandbox dashboard: https://sandbox-vendors.paddle.com → Developer tools → Authentication
# Live dashboard:    https://vendors.paddle.com → Developer tools → Authentication
#
# Server API keys (secret — never expose to the browser)
PADDLE_SANDBOX_API_KEY=pdl_sdbx_apikey_...
PADDLE_LIVE_API_KEY=pdl_live_apikey_...
# Active key used by the Node SDK (pick one env at a time)
# Sandbox: copy of PADDLE_SANDBOX_API_KEY | Live: copy of PADDLE_LIVE_API_KEY
PADDLE_API_KEY=pdl_sdbx_apikey_...
# sandbox | production
PADDLE_ENV=sandbox
#
# Client-side token for Paddle.js (safe to expose; prefix test_ or live_)
PADDLE_CLIENT_TOKEN=test_...
#
# Webhook destination secret (from Developer tools → Notifications)
PADDLE_NOTIFICATION_WEBHOOK_SECRET=pdl_ntfset_...

# Copy to .env and fill with your keys. Never commit .env.

PORT=4242

# Site URL (used for return URLs)
SITE_URL=http://localhost:8080

# Razorpay — https://dashboard.razorpay.com/app/keys
# Use Test keys for development (rzp_test_...)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# Stripe — https://dashboard.stripe.com/apikeys (optional)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal — https://developer.paypal.com/dashboard/ (optional)
PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...
# sandbox | live
PAYPAL_MODE=sandbox

# Supabase (server entitlements — required for Pro grants)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # secret — never ship to the browser
RAZORPAY_WEBHOOK_SECRET=           # Razorpay Dashboard → Webhooks
ALLOWED_ORIGINS=http://localhost:8080,https://xfreeze.com

# Paddle Billing — primary payment provider for X Freeze Pro
# Guides: docs/PADDLE-SETUP.md · docs/PADDLE-LIVE-MIGRATION.md
# Sandbox: https://sandbox-vendors.paddle.com
# Live:    https://vendors.paddle.com
#
# Sandbox (testing):
# PADDLE_ENV=sandbox
# PADDLE_CLIENT_TOKEN=test_...
# PADDLE_API_KEY=pdl_sdbx_apikey_...
#
# Live (after catalog + domain approval — do not open to customers until verified):
PADDLE_ENV=production
PADDLE_CLIENT_TOKEN=live_...
PADDLE_API_KEY=pdl_live_apikey_...
PADDLE_NOTIFICATION_WEBHOOK_SECRET=pdl_ntfset_...
PADDLE_PRICE_PRO_MONTHLY=pri_...
PADDLE_PRICE_PRO_YEARLY=pri_...
# Optional: reject non-Paddle IPs (fetches https://api.paddle.com/ips)
# PADDLE_WEBHOOK_IP_ALLOWLIST=true
